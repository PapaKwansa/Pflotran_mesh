SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE SATURATED
    /
    SUBSURFACE_GEOMECHANICS geomech
      OPTIONS
        FLOW_COUPLING ONE_WAY_COUPLED
      /
    /
  /
END


SUBSURFACE

#=========================== discretization ===================================
GRID
  TYPE UNSTRUCTURED_explicit layers4.uge
END


#=========================== numerical methods ================================
NUMERICAL_METHODS FLOW
  TIMESTEPPER
    INITIAL_TIMESTEP_SIZE 1.d-6 day
    MAXIMUM_TIMESTEP_SIZE 1.d-2 day
  /
  NEWTON_SOLVER
    MAX_ITERATIONS 50
    ABSOLUTE_TOLERANCE 1.d-8
    RELATIVE_TOLERANCE 1.d-6
  /
END


#=========================== time control =====================================
TIME
  FINAL_TIME 25.d0 day
END

REFERENCE_PRESSURE 5.3E6


#=========================== material properties (FLOW) =======================
MATERIAL_PROPERTY overburden
  ID 1
  POROSITY 0.08
  PERMEABILITY
    PERM_ISO 5.d-18
  /
END

MATERIAL_PROPERTY bartlesville_sand
  ID 2
  POROSITY 0.20
  PERMEABILITY
    PERM_ISO 1.d-13
  /
END

MATERIAL_PROPERTY basal_layer
  ID 3
  POROSITY 0.06
  PERMEABILITY
    PERM_ISO 2.d-18
  /
END

MATERIAL_PROPERTY underburden
  ID 4
  POROSITY 0.08
  PERMEABILITY
    PERM_ISO 5.d-18
  /
END


#=========================== output options ===================================
OUTPUT
  ACKNOWLEDGE_VTK_FLAW
  SNAPSHOT_FILE
    TIMES day 0.d0 1.25d0 2.5d0 3.75d0 5.d0 6.25d0 7.5d0 8.75d0 10.d0 \
          11.25d0 12.5d0 13.75d0 15.d0 16.25d0 17.5d0 18.75d0 20.d0 \
          21.25d0 22.5d0 23.75d0 25.d0
    FORMAT VTK
    VARIABLES
      LIQUID_PRESSURE
    /
  /
END


#=========================== regions ==========================================
REGION All
  COORDINATES
    -1.d10 -1.d10 -1.d10
     1.d10  1.d10  1.d10
  /
END

REGION top        FILE top.ex        END
REGION bottom     FILE bottom.ex     END
REGION north      FILE north.ex      END
REGION south      FILE south.ex      END
REGION east       FILE east.ex       END
REGION west       FILE west.ex       END
REGION wellbore   FILE wellbore.ex   END


#=========================== flow conditions ==================================
FLOW_CONDITION initial
  TYPE
    LIQUID_PRESSURE DIRICHLET
  /
  LIQUID_PRESSURE 5.3E6
END

FLOW_CONDITION fixed_head
  TYPE
    LIQUID_PRESSURE DIRICHLET
  /
  LIQUID_PRESSURE 5.3E6
END

FLOW_CONDITION noflow
  TYPE
    LIQUID_PRESSURE DIRICHLET
  /
  LIQUID_PRESSURE 5.3E6
END


# -------- injection ramp (critical change) ----------
FLOW_CONDITION injection_ramp
  TYPE
    RATE SCALED_VOLUMETRIC_RATE VOLUME
  /
  RATE
    TIMES day 0.d0 1.d0
    VALUES 0.d0 1.d-3
  /
END


INITIAL_CONDITION
  FLOW_CONDITION initial
  REGION All
END


SOURCE_SINK inj
  FLOW_CONDITION injection_ramp
  REGION wellbore
END


BOUNDARY_CONDITION west_bc   FLOW_CONDITION fixed_head  REGION west   END
BOUNDARY_CONDITION east_bc   FLOW_CONDITION fixed_head  REGION east   END
BOUNDARY_CONDITION north_bc  FLOW_CONDITION fixed_head  REGION north  END
BOUNDARY_CONDITION south_bc  FLOW_CONDITION fixed_head  REGION south  END
BOUNDARY_CONDITION top_bc    FLOW_CONDITION noflow      REGION top    END
BOUNDARY_CONDITION bottom_bc FLOW_CONDITION noflow      REGION bottom END


STRATA
  FILE layers4_material_ids.h5
END

END_SUBSURFACE


#============================= geomechanics ==================================
GEOMECHANICS

GEOMECHANICS_GRID
  TYPE UNSTRUCTURED layers4.ugi
END

GEOMECHANICS_MAPPING_FILE layers4.mapping

GEOMECHANICS_REGION all_geomech        FILE layers4_all.vset        END
GEOMECHANICS_REGION west_geomech       FILE west.vset               END
GEOMECHANICS_REGION east_geomech       FILE east.vset               END
GEOMECHANICS_REGION north_geomech      FILE north.vset              END
GEOMECHANICS_REGION south_geomech      FILE south.vset              END
GEOMECHANICS_REGION bottom_geomech     FILE bottom.vset             END
GEOMECHANICS_REGION top_geomech        FILE top.vset                END

GEOMECHANICS_REGION overburden         FILE overburden.vset         END
GEOMECHANICS_REGION bartlesville_sand  FILE bartlesville_sand.vset  END
GEOMECHANICS_REGION basal_layer        FILE basal_layer.vset        END
GEOMECHANICS_REGION underburden        FILE underburden.vset        END


# Roller BCs
GEOMECHANICS_CONDITION west_roller
  TYPE DISPLACEMENT_X DIRICHLET
  DISPLACEMENT_X 0.d0
END

GEOMECHANICS_CONDITION east_roller
  TYPE DISPLACEMENT_X DIRICHLET
  DISPLACEMENT_X 0.d0
END

GEOMECHANICS_CONDITION north_roller
  TYPE DISPLACEMENT_Y DIRICHLET
  DISPLACEMENT_Y 0.d0
END

GEOMECHANICS_CONDITION south_roller
  TYPE DISPLACEMENT_Y DIRICHLET
  DISPLACEMENT_Y 0.d0
END

GEOMECHANICS_CONDITION bottom_roller
  TYPE DISPLACEMENT_Z DIRICHLET
  DISPLACEMENT_Z 0.d0
END


GEOMECHANICS_BOUNDARY_CONDITION west_bc   GEOMECHANICS_CONDITION west_roller   GEOMECHANICS_REGION west_geomech   END
GEOMECHANICS_BOUNDARY_CONDITION east_bc   GEOMECHANICS_CONDITION east_roller   GEOMECHANICS_REGION east_geomech   END
GEOMECHANICS_BOUNDARY_CONDITION north_bc  GEOMECHANICS_CONDITION north_roller  GEOMECHANICS_REGION north_geomech  END
GEOMECHANICS_BOUNDARY_CONDITION south_bc  GEOMECHANICS_CONDITION south_roller  GEOMECHANICS_REGION south_geomech  END
GEOMECHANICS_BOUNDARY_CONDITION bottom_bc GEOMECHANICS_CONDITION bottom_roller GEOMECHANICS_REGION bottom_geomech END


GEOMECHANICS_MATERIAL_PROPERTY overburden
  ID 1
  ROCK_DENSITY 2500.d0
  YOUNGS_MODULUS 2.0d10
  POISSONS_RATIO 0.28d0
  BIOT_COEFFICIENT 0.7d0
END

GEOMECHANICS_MATERIAL_PROPERTY bartlesville_sand
  ID 2
  ROCK_DENSITY 2500.d0
  YOUNGS_MODULUS 9.0d9
  POISSONS_RATIO 0.25d0
  BIOT_COEFFICIENT 0.9d0
END

GEOMECHANICS_MATERIAL_PROPERTY basal_layer
  ID 3
  ROCK_DENSITY 2500.d0
  YOUNGS_MODULUS 2.5d10
  POISSONS_RATIO 0.28d0
  BIOT_COEFFICIENT 0.7d0
END

GEOMECHANICS_MATERIAL_PROPERTY underburden
  ID 4
  ROCK_DENSITY 2500.d0
  YOUNGS_MODULUS 2.0d10
  POISSONS_RATIO 0.28d0
  BIOT_COEFFICIENT 0.7d0
END


GEOMECHANICS_STRATA
  GEOMECHANICS_REGION overburden
  GEOMECHANICS_MATERIAL overburden
END

GEOMECHANICS_STRATA
  GEOMECHANICS_REGION bartlesville_sand
  GEOMECHANICS_MATERIAL bartlesville_sand
END

GEOMECHANICS_STRATA
  GEOMECHANICS_REGION basal_layer
  GEOMECHANICS_MATERIAL basal_layer
END

GEOMECHANICS_STRATA
  GEOMECHANICS_REGION underburden
  GEOMECHANICS_MATERIAL underburden
END


GEOMECHANICS_OUTPUT
  TIMES day 0.d0 1.25d0 2.5d0 3.75d0 5.d0 6.25d0 7.5d0 8.75d0 10.d0 \
        11.25d0 12.5d0 13.75d0 15.d0 16.25d0 17.5d0 18.75d0 20.d0 \
        21.25d0 22.5d0 23.75d0 25.d0
  FORMAT HDF5
END

END
